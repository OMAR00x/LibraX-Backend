            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"علي\",\n  \"last_name\": \"خالد\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {"raw": "{{base_url}}/auth/profile", "host": ["{{base_url}}"], "path": ["auth", "profile"]}
          }
